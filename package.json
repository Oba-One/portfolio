{
  "name": "portfolio",
  "version": "1.0.0",
  "packageManager": "bun@1.3.10",
  "homepage": "https://afolabi.info",
  "description": "Portfolio site for Afolabi Aiyeloja",
  "repository": "https://github.com/Oba-One/portfolio.git",
  "author": "Afolabi Aiyeloja <afo@wefa.app>",
  "scripts": {
    "dev": "next dev",
    "storybook": "storybook dev -p 9009 -h localhost",
    "build": "next build",
    "build:storybook": "storybook build -o build-storybook && node scripts/draco-storybook",
    "start": "next start",
    "test": "echo 'write some tests'",
    "lint": "eslint src --ext js,jsx,ts,tsx",
    "prettier": "prettier --write '**/*.{js,jsx,ts,tsx,md,mdx}'",
    "optimize:assets": "zsh scripts/optimize-assets.sh",
    "optimize:resize": "bunx @squoosh/cli -s '-mobile' --webp auto --resize \"{'enabled':true,'width':'25%','height':'25%','method':'lanczos3'}\" src/assets/*.webp"
  },
  "dependencies": {
    "@sentry/browser": "10.52.0",
    "@sentry/nextjs": "10.52.0",
    "@vercel/analytics": "2.0.1",
    "cors": "2.8.6",
    "framer-motion": "^7.10.3",
    "next": "15.5.18",
    "nodemailer": "8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.146.0",
    "three-stdlib": "^2.36.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@squoosh/cli": "^0.7.3",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/nextjs": "10.3.6",
    "@storybook/react": "10.3.6",
    "@svgr/webpack": "8.1.0",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.19.18",
    "@types/react": "18.0.21",
    "@types/react-dom": "18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "esbuild": "0.27.7",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "8.6.0",
    "fs-extra": "^10.1.0",
    "globby": "^13.2.2",
    "mdx-bundler": "10.1.1",
    "postcss": "^8.5.14",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^7.8.3",
    "prettier": "^2.8.8",
    "sass": "^1.99.0",
    "storybook": "10.3.6",
    "typescript": "4.9.5"
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 90,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  },
  "overrides": {
    "@rollup/pluginutils": "5.3.0",
    "bn.js": "^4.12.3 || ^5.2.3",
    "brace-expansion": "^1.1.12 || ^5.0.6",
    "browserify-rsa": "4.1.1",
    "browserify-sign": "4.2.5",
    "cipher-base": "1.0.7",
    "cross-spawn": "7.0.6",
    "elliptic": "6.6.1",
    "flatted": "3.4.2",
    "js-yaml": "^3.14.2 || ^4.1.1",
    "micromatch": "4.0.8",
    "minimatch": "^3.1.3 || ^10.2.5",
    "pbkdf2": "3.1.5",
    "picomatch": "^2.3.2 || ^4.0.4",
    "postcss": "8.5.14",
    "semver": "^6.3.1 || ^7.8.0",
    "sha.js": "2.4.12",
    "terser-webpack-plugin": "5.6.0",
    "webpack": "5.106.2"
  },
  "eslintConfig": {
    "env": {
      "es6": true
    },
    "extends": [
      "next",
      "next/core-web-vitals",
      "plugin:@typescript-eslint/recommended",
      "prettier"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "prefer-const": "error",
      "no-unused-vars": "warn",
      "import/no-anonymous-default-export": "off",
      "react/display-name": "off",
      "@next/next/no-img-element": "off"
    }
  },
  "browserslist": {
    "production": [
      ">10%",
      "not dead",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22.0.0"
  }
}
